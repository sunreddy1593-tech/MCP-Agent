# Copy to .env and fill in. Never commit .env.

# Groq LLM API key (https://console.groq.com/keys)
GROQ_API_KEY=

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Phase 6 delivery: Google Workspace MCP server -----------------------
# The pipeline is an MCP *client* of the Google Workspace server
# (github.com/sunreddy1593-tech/MCP-1), which exposes append_to_google_doc,
# draft_gmail, and send_gmail. Leave these unset to run stages 1-5 and keep the
# rendered pulse locally (delivery status "pending").

# Transport: "http" (streamable HTTP, default) or "stdio" (spawn the server).
# MCP_WORKSPACE_TRANSPORT=http

# HTTP transport: the server's streamable endpoint + its bearer token.
# MCP_WORKSPACE_URL=http://127.0.0.1:3333/mcp
# MCP_WORKSPACE_AUTH_TOKEN=

# stdio transport (alternative to HTTP): command + args to launch the server.
# MCP_WORKSPACE_TRANSPORT=stdio
# MCP_WORKSPACE_COMMAND=node
# MCP_WORKSPACE_ARGS=/absolute/path/to/dist/index.js
